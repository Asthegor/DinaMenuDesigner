<Window x:Class="DinaMenuDesigner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:DinaMenuDesigner.Models"
        xmlns:common="clr-namespace:DinaMenuDesigner.Common"
        xmlns:views="clr-namespace:DinaMenuDesigner.Views"
        mc:Ignorable="d"
        Title="DinaMenuDesigner"
        Width="1280" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen" ScrollViewer.VerticalScrollBarVisibility="Disabled">
    <Window.Resources>
        <common:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
        <common:IsSelectedConverter x:Key="IsSelectedConverter"/>
        <common:MenuElementToBoolConverter x:Key="MenuElementToBoolConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Colonne gauche -->
        <Grid Grid.Column="0" Background="#1E1E1E">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Button Command="{Binding SaveCommand}"
                        Content="Sauver"/>
                <Button Command="{Binding LoadCommand}"
                        Content="Charger"/>
                <Button Command="{Binding GenerateCommand}"
                        Content="Générer"/>
            </StackPanel>
            
            <!-- Section Titres (ligne 1) -->
            <Grid Grid.Row="1" Margin="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- En-tête de la section Titres -->
                <views:SectionTitleView Label="Titres" Command="{Binding AddTitleCommand}"/>
                <!-- Liste des titres -->
                <ListBox Grid.Row="1"
                         x:Name="TitlesListBox"
                         ItemsSource="{Binding MenuManager.Titles}"
                         SelectedItem="{Binding SelectedTitle, Mode=TwoWay}"
                         Background="#2D2D2D"
                         Foreground="White"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <views:ListBoxItemView Label="T"
                                                   ElementContent="{Binding Content}"
                                                   UpCommand="{Binding DataContext.MoveTitleUpCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                   DownCommand="{Binding DataContext.MoveTitleDownCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                   RemoveCommand="{Binding DataContext.RemoveTitleCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Séparateur horizontal entre Titres et Items -->
            <GridSplitter Grid.Row="2"
                          Height="4"
                          HorizontalAlignment="Stretch"
                          Background="#444444"/>


            <!-- Section Items (ligne 3) -->
            <Grid Grid.Row="3" Margin="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- En-tête de la section Items -->
                <views:SectionTitleView Label="Items" Command="{Binding AddItemCommand}"/>

                <!-- Liste des items -->
                <ListBox Grid.Row="1"
                         x:Name="ItemsListBox"
                         ItemsSource="{Binding MenuManager.Items}"
                         SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                         Background="#2D2D2D"
                         Foreground="White"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <views:ListBoxItemView Label="I"
                                                   ElementContent="{Binding Content}"
                                                   UpCommand="{Binding DataContext.MoveItemUpCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                   DownCommand="{Binding DataContext.MoveItemDownCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                   RemoveCommand="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- Séparateur gauche -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#444444"/>

        <!-- Colonne centre -->
        <Viewbox x:Name="PreviewViewbox" Grid.Column="2" Stretch="Uniform">
            <Canvas x:Name="PreviewCanvas" Width="1920" Height="1080" Background="Black">
                <ItemsControl ItemsSource="{Binding MenuManager.Titles}" Width="1920" Height="1080">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:CanvasItemView ElementContent="{Binding Content}"
                                                  ElementColor="{Binding Color}"
                                                  FontSize="{Binding FontSize}"
                                                  PositionX="{Binding PositionX}"
                                                  PositionY="{Binding PositionY}"
                                                  SelectionRequested="OnSelectionRequested"
                                                  PositionChanged="OnPositionChanged">
                                <views:CanvasItemView.IsSelected>
                                    <MultiBinding Converter="{StaticResource IsSelectedConverter}">
                                        <Binding Path="DataContext.SelectedElement" 
                                                 RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding/>
                                    </MultiBinding>
                                </views:CanvasItemView.IsSelected>
                            </views:CanvasItemView>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemContainerStyle>
                        <Style>
                            <Setter Property="Canvas.Left" Value="{Binding PositionX}"/>
                            <Setter Property="Canvas.Top" Value="{Binding PositionY}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding MenuManager.Items}" Width="1920" Height="1080">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:CanvasItemView ElementContent="{Binding Content}"
                                                  ElementColor="{Binding DisplayColor}"
                                                  FontSize="{Binding FontSize}"
                                                  PositionX="{Binding PositionX}"
                                                  PositionY="{Binding PositionY}"
                                                  SelectionRequested="OnSelectionRequested"
                                                  PositionChanged="OnPositionChanged">
                                <views:CanvasItemView.IsSelected>
                                    <MultiBinding Converter="{StaticResource IsSelectedConverter}">
                                        <Binding Path="DataContext.SelectedElement" 
                                                 RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        <Binding/>
                                    </MultiBinding>
                                </views:CanvasItemView.IsSelected>
                            </views:CanvasItemView>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemContainerStyle>
                        <Style>
                            <Setter Property="Canvas.Left" Value="{Binding PositionX}"/>
                            <Setter Property="Canvas.Top" Value="{Binding PositionY}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </Canvas>
        </Viewbox>

        <!-- Séparateur droit -->
        <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch" Background="#444444"/>

        <!-- Colonne droite -->
        <Grid Grid.Column="4" Background="#1E1E1E">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="200"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Ligne 0 : Propriétés globales du MenuManager -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Propriétés du menu"
                           Foreground="White"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <!-- Direction du menu -->
                        <views:EnumComboBoxView Label="Direction"
                                                EnumType="{x:Type common:MenuDirection}"
                                                SelectedValue="{Binding MenuManager.Direction, Mode=TwoWay}"/>

                        <!-- Espacement des items du menu -->
                        <views:PropertyRowView Label="Espacement X" Value="{Binding MenuManager.SpacingX, Mode=TwoWay}"/>
                        <views:PropertyRowView Label="Espacement Y" Value="{Binding MenuManager.SpacingY, Mode=TwoWay}"/>

                        <!-- Position des items du menu -->
                        <views:PropertyRowView Label="Position Items X" Value="{Binding MenuManager.ItemsPositionX, Mode=TwoWay}"/>
                        <views:PropertyRowView Label="Position Items Y" Value="{Binding MenuManager.ItemsPositionY, Mode=TwoWay}"/>

                        <!-- Centrer les titres -->
                        <CheckBox Content="Centrer les titres"
                                  Foreground="White"
                                  IsChecked="{Binding MenuManager.CenterTitles, Mode=TwoWay}"
                                  Margin="0,0,0,4"/>

                        <!-- Centrer les items -->
                        <CheckBox Content="Centrer les items"
                                  Foreground="White"
                                  IsChecked="{Binding MenuManager.CenterItems, Mode=TwoWay}"
                                  Margin="0,0,0,4"/>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Ligne 1 : Séparateur -->
            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="#444444"/>

            <!-- Ligne 2 : Propriétés de l'élément sélectionné -->
            <ContentControl Grid.Row="2" Content="{Binding SelectedElement, Mode=OneWay}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type models:TitleModel}">
                        <views:TitlePropertiesView/>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type models:MenuItemModel}">
                        <views:ItemPropertiesView/>
                    </DataTemplate>

                </ContentControl.Resources>
            </ContentControl>
        </Grid>
    </Grid>
</Window>