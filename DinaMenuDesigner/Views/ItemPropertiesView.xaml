<UserControl x:Class="DinaMenuDesigner.Views.ItemPropertiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DinaMenuDesigner.Views"
             xmlns:common="clr-namespace:DinaMenuDesigner.Common"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                    Text="Propriétés de l'item"
                    Foreground="White"
                    FontWeight="Bold"
                    Margin="0,0,0,8"/>

        <ScrollViewer Grid.Row="1"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">
                <local:PropertyRowView Label="Texte" Value="{Binding Content, Mode=TwoWay}"/>

                <local:PropertyRowView Label="Position X" Value="{Binding PositionX, Mode=TwoWay}"/>
                <local:PropertyRowView Label="Position Y" Value="{Binding PositionY, Mode=TwoWay}"/>

                <local:PropertyRowView Label="Police" Value="{Binding PlaceholderFont, Mode=TwoWay}"/>
                <local:PropertyRowView Label="Taille Police" Value="{Binding FontSize, Mode=TwoWay}"/>
                <local:PropertyRowView Label="Couleur" Value="{Binding Color, Mode=TwoWay}"/>
                <local:PropertyRowView Label="ZOrder" Value="{Binding ZOrder, Mode=TwoWay}"/>

                <CheckBox Content="Visible"
                            Foreground="White"
                            IsChecked="{Binding Visible, Mode=TwoWay}"
                            Margin="0,0,0,6"/>

                <CheckBox Content="Activé"
                            Foreground="White"
                            IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                            Margin="0,0,0,6"/>

                <local:PropertyRowView Label="Couleur lorsque désactivé"
                                        Value="{Binding DisableColor, Mode=TwoWay}"/>

                <local:EnumComboBoxView Label="Alignement horizontal"
                                        EnumType="{x:Type common:DinaHorizontalAlignment}"
                                        SelectedValue="{Binding HorizontalAlignment, Mode=TwoWay}"/>
                <local:EnumComboBoxView Label="Alignement vertical"
                                        EnumType="{x:Type common:DinaVerticalAlignment}"
                                        SelectedValue="{Binding VerticalAlignment, Mode=TwoWay}"/>

                <!-- Méthodes -->
                <local:PropertyRowView Label="Méthode Sélection" Value="{Binding SelectionMethodName, Mode=TwoWay}"/>
                <local:PropertyRowView Label="Méthode Désélection" Value="{Binding DeselectionMethodName, Mode=TwoWay}"/>
                <local:PropertyRowView Label="Méthode Activation" Value="{Binding ActivationMethodName, Mode=TwoWay}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
