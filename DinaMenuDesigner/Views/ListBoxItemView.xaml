<UserControl x:Class="DinaMenuDesigner.Views.ListBoxItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DinaMenuDesigner.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
                   Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Foreground="#888888"
                   FontWeight="Bold"
                   Margin="0,0,6,0"
                   VerticalAlignment="Center"/>
        <TextBlock Grid.Column="1"
                   Text="{Binding ElementContent, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   VerticalAlignment="Center"/>
        <Button Grid.Column="2"
                Content="↑"
                Width="24" Height="24"
                Margin="2,0"
                Command="{Binding UpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"/>
        <Button Grid.Column="3"
                Content="↓"
                Width="24" Height="24"
                Margin="2,0"
                Command="{Binding DownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"/>
        <Button Grid.Column="4"
                Content="🗑️"
                Width="28" Height="24"
                Margin="2,0"
                Command="{Binding RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandParameter="{Binding}"/>
    </Grid>
</UserControl>
