<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DinaMenuDesigner.Views"
             x:Class="DinaMenuDesigner.Views.PropertyRowView"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>
        <TextBlock Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Foreground="#AAAAAA"
                   Margin="0,0,0,2"/>
        <TextBox Text="{Binding Value, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 Margin="0,0,0,6"/>
    </StackPanel>
</UserControl>
